# ══════════════════════════════════════
# AI OFFICE PILOT - Configuration
# ══════════════════════════════════════
# Copy this to .env and fill in your values

# ─── Ollama Settings ───
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=phi3:mini
OLLAMA_BACKUP_MODEL=llama3.2:3b

# ─── Email Account 1 ───
EMAIL_1_ADDRESS=your.email@gmail.com
EMAIL_1_PASSWORD=your_app_password
EMAIL_1_IMAP_HOST=imap.gmail.com
EMAIL_1_IMAP_PORT=993
EMAIL_1_SMTP_HOST=smtp.gmail.com
EMAIL_1_SMTP_PORT=587
EMAIL_1_LABEL=Personal

# ─── Email Account 2 (Optional) ───
# EMAIL_2_ADDRESS=
# EMAIL_2_PASSWORD=
# EMAIL_2_IMAP_HOST=
# EMAIL_2_IMAP_PORT=
# EMAIL_2_SMTP_HOST=
# EMAIL_2_SMTP_PORT=
# EMAIL_2_LABEL=

# ─── File Watching ───
WATCH_FOLDERS=~/Downloads,~/Desktop,~/Documents/Inbox
ORGANIZED_ROOT=~/Documents/Organized

# ─── Spreadsheet ───
SPREADSHEET_TYPE=local
# SPREADSHEET_TYPE=google
# GOOGLE_SHEETS_CRED_FILE=credentials.json
# GOOGLE_SHEET_ID=your_sheet_id

# ─── Dashboard ───
DASHBOARD_PORT=5000
DASHBOARD_HOST=127.0.0.1

# ─── Demo Mode ───
DEMO_MODE=false
SETUP_COMPLETE=false

# ─── Security ───
# Generate a secure JWT secret: python -c 'import secrets; print(secrets.token_hex(32))'
JWT_SECRET=your-generated-jwt-secret-here
# Generate a secure Flask secret: python -c 'import secrets; print(secrets.token_hex(32))'
FLASK_SECRET_KEY=your-generated-flask-secret-key-here
AUTO_LOCK_MINUTES=30
SESSION_TIMEOUT_HOURS=8
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_MINUTES=15

# ─── Data Retention (days) ───
RETENTION_EMAIL_CONTENT=30
RETENTION_ATTACHMENTS=7
RETENTION_TEMP_FILES=1
RETENTION_AUDIT_LOGS=2555
RETENTION_INVOICES=365

# ─── Notifications ───
ENABLE_DESKTOP_NOTIFICATIONS=true
ENABLE_SOUND=true

# ─── Compliance ───
ENABLE_GDPR=false
ENABLE_HIPAA=false

# ─── Performance ───
CYCLE_INTERVAL_MINUTES=5
MAX_EMAILS_PER_CYCLE=50
MAX_FILES_PER_CYCLE=30

# ─── Rate Limiting ───
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=10
RATE_LIMIT_UNAUTHENTICATED=10

# ─── Network Security ───
NETWORK_MODE=normal  # normal, isolated, air_gapped
VPN_ENABLED=false
VPN_NAME=
VPN_AUTO_CONNECT=false
ALLOWED_IPS=
ENABLE_IP_ALLOWLIST=false

# ─── Bytez (Optional Cloud Backup for Heavy Tasks) ───
# BYTEZ_API_KEY=
# USE_BYTEZ_FOR_HEAVY=false