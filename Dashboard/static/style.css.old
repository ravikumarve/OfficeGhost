:root {
  /* Backgrounds — layered depth */
  --bg-base:        #0A0A0B;    /* page background — near black */
  --bg-surface:     #111113;    /* cards, panels */
  --bg-elevated:    #1A1A1E;    /* modals, dropdowns, hover surfaces */
  --bg-subtle:      #222228;    /* input backgrounds, code blocks */

  /* Borders */
  --border-default: #2A2A32;    /* default border */
  --border-strong:  #3A3A45;    /* focused, active borders */
  --border-glow:    #F59E0B40;  /* amber glow border on focus/hover */

  /* Amber Accent — the soul of GhostOffice */
  --accent:         #F59E0B;    /* primary amber */
  --accent-hover:   #FBBF24;    /* lighter on hover */
  --accent-dim:     #F59E0B20;  /* subtle amber tint backgrounds */
  --accent-glow:    0 0 20px #F59E0B35; /* box-shadow glow */

  /* Text hierarchy */
  --text-primary:   #F1F0EE;    /* headlines, important content */
  --text-secondary: #A09FA6;    /* body copy, descriptions */
  --text-muted:     #5C5B63;    /* timestamps, captions, placeholders */
  --text-accent:    #F59E0B;    /* links, highlights, active labels */

  /* Semantic */
  --success: #10B981;
  --warning: #F59E0B;
  --error:   #EF4444;
  --info:    #6366F1;

  /* Spacing */
  --space-4: 4px;
  --space-8: 8px;
  --space-12: 12px;
  --space-16: 16px;
  --space-24: 24px;
  --space-32: 32px;
  --space-48: 48px;
  --space-64: 64px;
}

* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

body {
  font-family: 'DM Sans', -apple-system, sans-serif;
  background: var(--bg-base);
  color: var(--text-primary);
  min-height: 100vh;
  line-height: 1.6;
}

body::before {
  content: '';
  position: fixed;
  inset: 0;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter'%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.03'/%3E%3C/svg%3E");
  pointer-events: none;
  z-index: 0;
}

/* ─── Demo Mode Banner ─── */
.demo-banner {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 300;
  background: linear-gradient(90deg, var(--accent) 0%, #FBBF24 100%);
  color: #0A0A0B;
  padding: var(--space-12) var(--space-16);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--space-8);
  font-size: 0.85rem;
  font-weight: 500;
}

/* ─── Sidebar ─── */
.sidebar {
  position: fixed;
  left: 0;
  top: 0;
  bottom: 0;
  width: 240px;
  background: var(--bg-surface);
  border-right: 1px solid var(--border-default);
  display: flex;
  flex-direction: column;
  padding: var(--space-24);
  z-index: 100;
}

.sidebar-header {
  text-align: center;
  margin-bottom: var(--space-32);
  padding-bottom: var(--space-24);
  border-bottom: 1px solid var(--border-default);
}

.logo {
  font-size: 2rem;
  display: block;
  margin-bottom: var(--space-8);
}

.sidebar-header h2 {
  font-family: 'Syne', sans-serif;
  font-size: 1.1rem;
  font-weight: 700;
  color: var(--text-primary);
  letter-spacing: -0.02em;
}

.version {
  font-size: 0.75rem;
  color: var(--text-muted);
  background: var(--bg-elevated);
  padding: var(--space-4) var(--space-8);
  border-radius: 12px;
  display: inline-block;
  margin-top: var(--space-4);
  font-family: 'JetBrains Mono', monospace;
}

.nav-links {
  list-style: none;
  flex: 1;
}

.nav-links li {
  margin-bottom: var(--space-4);
}

.nav-links a {
  display: flex;
  align-items: center;
  gap: var(--space-12);
  padding: var(--space-12) var(--space-16);
  color: var(--text-secondary);
  text-decoration: none;
  border-radius: 6px;
  transition: all 200ms cubic-bezier(0.4, 0, 0.2, 1);
  font-weight: 500;
}

.nav-links a:hover {
  background: var(--bg-elevated);
  color: var(--text-primary);
}

.nav-links .active a {
  background: var(--accent-dim);
  color: var(--accent);
  border-left: 2px solid var(--accent);
  font-weight: 500;
}

.nav-links .icon {
  font-size: 1.1rem;
}

.sidebar-footer {
  border-top: 1px solid var(--border-default);
  padding-top: var(--space-16);
}

.security-badge {
  display: flex;
  align-items: center;
  gap: var(--space-8);
  font-size: 0.8rem;
  color: var(--success);
  margin-bottom: var(--space-16);
  font-family: 'JetBrains Mono', monospace;
}

.dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  display: inline-block;
}

.dot.green { background: var(--success); box-shadow: 0 0 6px var(--success); }

.logout-btn {
  display: block;
  text-align: center;
  padding: var(--space-12);
  background: var(--bg-elevated);
  color: var(--text-secondary);
  text-decoration: none;
  border-radius: 6px;
  font-size: 0.85rem;
  transition: all 200ms cubic-bezier(0.4, 0, 0.2, 1);
}

.logout-btn:hover {
  background: var(--error);
  color: white;
}

/* ─── Main Content ─── */
main {
  padding: var(--space-32);
  max-width: 1160px;
  margin: 0 auto;
}

main.with-sidebar {
  margin-left: 240px;
}

.page-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: var(--space-32);
  position: relative;
}

.page-header h1 {
  font-family: 'Syne', sans-serif;
  font-size: 1.75rem;
  font-weight: 700;
  letter-spacing: -0.02em;
}

.subtitle {
  color: var(--text-secondary);
  margin-top: var(--space-4);
}

/* ─── Cards ─── */
.card {
  background: var(--bg-surface);
  border: 1px solid var(--border-default);
  border-radius: 8px;
  padding: var(--space-24);
  margin-bottom: var(--space-24);
  transition: border-color 200ms ease, box-shadow 200ms ease;
}

.card:hover {
  border-color: var(--border-strong);
  box-shadow: var(--accent-glow);
}

.card h3 {
  font-family: 'Syne', sans-serif;
  font-size: 1.1rem;
  margin-bottom: var(--space-16);
  color: var(--text-primary);
  letter-spacing: -0.02em;
}

.card-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
  gap: var(--space-16);
  margin-bottom: var(--space-24);
}

/* Enhanced Card Variants */
.card-primary {
  border-left: 4px solid var(--accent);
  background: linear-gradient(135deg, var(--bg-surface) 0%, var(--bg-elevated) 100%);
}

.card-warning {
  border-left: 4px solid var(--warning);
}

.card-success {
  border-left: 4px solid var(--success);
}

.card-error {
  border-left: 4px solid var(--error);
}

.card-highlight {
  background: var(--accent-dim);
  border: 1px solid var(--accent);
  box-shadow: var(--accent-glow);
}

/* Card Header with Action */
.card-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: var(--space-16);
}

.card-header h3 {
  margin-bottom: 0;
}

.card-actions {
  display: flex;
  gap: var(--space-8);
}

.card-action-btn {
  background: none;
  border: none;
  color: var(--text-secondary);
  cursor: pointer;
  padding: var(--space-4);
  border-radius: 4px;
  transition: all 200ms ease;
}

.card-action-btn:hover {
  background: var(--bg-elevated);
  color: var(--text-primary);
}

/* Card Metrics */
.card-metric {
  display: flex;
  flex-direction: column;
  gap: var(--space-8);
}

.metric-value {
  font-family: 'Syne', sans-serif;
  font-size: 2rem;
  font-weight: 700;
  color: var(--text-primary);
  line-height: 1;
}

.metric-value.accent {
  color: var(--accent);
}

.metric-value.success {
  color: var(--success);
}

.metric-value.warning {
  color: var(--warning);
}

.metric-value.error {
  color: var(--error);
}

.metric-label {
  font-size: 0.85rem;
  color: var(--text-secondary);
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.metric-change {
  font-size: 0.8rem;
  font-family: 'JetBrains Mono', monospace;
}

.metric-change.positive {
  color: var(--success);
}

.metric-change.negative {
  color: var(--error);
}

/* Card Grid Layouts */
.card-grid-compact {
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: var(--space-12);
}

.card-grid-spacious {
  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  gap: var(--space-24);
}

/* Section Headers */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-bottom: var(--space-24);
  padding-bottom: var(--space-12);
  border-bottom: 1px solid var(--border-default);
}

.section-header h2 {
  font-family: 'Syne', sans-serif;
  font-size: 1.5rem;
  font-weight: 700;
  color: var(--text-primary);
  letter-spacing: -0.02em;
  margin: 0;
}

.section-description {
  color: var(--text-secondary);
  font-size: 0.95rem;
  margin-top: var(--space-4);
}

.section-actions {
  display: flex;
  gap: var(--space-8);
}

/* ─── Buttons ─── */
.btn-primary {
  background: var(--accent);
  color: #0A0A0B;
  border: none;
  padding: var(--space-12) var(--space-20);
  border-radius: 6px;
  font-size: 0.9rem;
  font-weight: 500;
  cursor: pointer;
  transition: all 200ms cubic-bezier(0.4, 0, 0.2, 1);
  font-family: 'DM Sans';
  letter-spacing: 0.01em;
  min-width: 80px;
}

.btn-primary:hover {
  background: var(--accent-hover);
  box-shadow: 0 0 16px #F59E0B50;
}

.btn-secondary {
  background: transparent;
  border: 1px solid var(--border-default);
  color: var(--text-secondary);
  padding: var(--space-12) var(--space-20);
  border-radius: 6px;
  font-size: 0.9rem;
  font-weight: 500;
  cursor: pointer;
  transition: all 200ms cubic-bezier(0.4, 0, 0.2, 1);
}

.btn-secondary:hover {
  background: var(--bg-elevated);
  color: var(--text-primary);
  border-color: var(--border-strong);
}

/* ─── Flash Messages ─── */
.flash-messages {
  margin-bottom: var(--space-24);
}

.flash {
  padding: var(--space-12) var(--space-16);
  border-radius: 6px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--space-8);
  font-size: 0.9rem;
}

.flash.error { background: rgba(239, 68, 68, 0.1); border: 1px solid rgba(239, 68, 68, 0.2); color: var(--error); }
.flash.success { background: rgba(34, 197, 94, 0.1); border: 1px solid rgba(34, 197, 94, 0.2); color: var(--success); }

.flash-close {
  background: none;
  border: none;
  color: inherit;
  cursor: pointer;
  font-size: 1rem;
}

/* ─── Notification Bell ─── */
.notification-bell {
  position: fixed;
  top: var(--space-16);
  right: var(--space-24);
  z-index: 200;
}

.bell-btn {
  position: relative;
  background: var(--bg-surface);
  border: 1px solid var(--border-default);
  border-radius: 50%;
  width: 44px;
  height: 44px;
  font-size: 1.3rem;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 200ms cubic-bezier(0.4, 0, 0.2, 1);
}

.bell-btn:hover {
  background: var(--bg-elevated);
  transform: translateY(-1px);
}

.bell-badge {
  position: absolute;
  top: -4px;
  right: -4px;
  background: var(--error);
  color: white;
  font-size: 0.7rem;
  font-weight: 700;
  min-width: 18px;
  height: 18px;
  border-radius: 9px;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 var(--space-4);
  font-family: 'JetBrains Mono', monospace;
}

.notification-dropdown {
  display: none;
  position: absolute;
  top: 52px;
  right: 0;
  width: 360px;
  max-height: 480px;
  background: var(--bg-surface);
  border: 1px solid var(--border-default);
  border-radius: 8px;
  box-shadow: var(--accent-glow);
  overflow: hidden;
}

.dropdown-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--space-16);
  border-bottom: 1px solid var(--border-default);
  background: var(--bg-elevated);
}

.dropdown-header span {
  font-weight: 600;
  font-size: 0.95rem;
  font-family: 'Syne', sans-serif;
}

.mark-read-btn {
  background: none;
  border: none;
  color: var(--accent);
  font-size: 0.8rem;
  cursor: pointer;
  padding: var(--space-4) var(--space-8);
  border-radius: 4px;
  transition: background 200ms ease;
}

.mark-read-btn:hover {
  background: var(--accent-dim);
}

.notification-list {
  max-height: 400px;
  overflow-y: auto;
}

.notification-item {
  display: flex;
  gap: var(--space-12);
  padding: var(--space-16);
  border-bottom: 1px solid var(--border-default);
  transition: background 200ms ease;
}

.notification-item:hover {
  background: var(--bg-elevated);
}

.notification-item.unread {
  background: var(--accent-dim);
  border-left: 3px solid var(--accent);
}

.notif-icon {
  font-size: 1.2rem;
  flex-shrink: 0;
  width: 28px;
  text-align: center;
}

.notif-content {
  flex: 1;
  min-width: 0;
}

.notif-title {
  font-weight: 600;
  font-size: 0.85rem;
  color: var(--text-primary);
  margin-bottom: var(--space-4);
}

.notif-message {
  font-size: 0.8rem;
  color: var(--text-secondary);
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.notif-time {
  font-size: 0.7rem;
  color: var(--text-muted);
  margin-top: var(--space-8);
  font-family: 'JetBrains Mono', monospace;
}

.notification-empty,
.notification-loading {
  padding: var(--space-32);
  text-align: center;
  color: var(--text-muted);
  font-size: 0.9rem;
}

/* Mobile Menu Toggle */
.menu-toggle {
  display: none;
  position: fixed;
  top: var(--space-16);
  left: var(--space-16);
  z-index: 150;
  background: var(--bg-surface);
  border: 1px solid var(--border-default);
  border-radius: 6px;
  width: 44px;
  height: 44px;
  cursor: pointer;
  align-items: center;
  justify-content: center;
  transition: all 200ms ease;
}

.menu-toggle:hover {
  background: var(--bg-elevated);
  border-color: var(--border-strong);
}

.menu-toggle span {
  display: block;
  width: 20px;
  height: 2px;
  background: var(--text-primary);
  position: relative;
  transition: all 200ms ease;
}

.menu-toggle span::before,
.menu-toggle span::after {
  content: '';
  position: absolute;
  width: 20px;
  height: 2px;
  background: var(--text-primary);
  transition: all 200ms ease;
}

.menu-toggle span::before {
  transform: translateY(-6px);
}

.menu-toggle span::after {
  transform: translateY(6px);
}

.menu-toggle.active span {
  background: transparent;
}

.menu-toggle.active span::before {
  transform: rotate(45deg);
}

.menu-toggle.active span::after {
  transform: rotate(-45deg);
}

/* Enhanced Sidebar with Mobile Support */
.sidebar {
  position: fixed;
  left: 0;
  top: 0;
  bottom: 0;
  width: 280px;
  background: var(--bg-surface);
  border-right: 1px solid var(--border-default);
  display: flex;
  flex-direction: column;
  padding: var(--space-24);
  z-index: 100;
  transition: transform 300ms ease;
  transform: translateX(0);
}

/* Mobile Overlay */
.sidebar-overlay {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 90;
  opacity: 0;
  transition: opacity 300ms ease;
}

/* Enhanced Main Content */
main.with-sidebar {
  margin-left: 280px;
  transition: margin-left 300ms ease;
}

/* Focus States for Accessibility */
.btn-primary:focus,
.btn-secondary:focus,
.nav-links a:focus,
.bell-btn:focus,
.menu-toggle:focus {
  outline: 2px solid var(--accent);
  outline-offset: 2px;
}

input:focus,
textarea:focus {
  outline: 2px solid var(--accent);
  outline-offset: 2px;
  border-color: var(--accent);
}

/* Enhanced Card Grid */
.card-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: var(--space-24);
  margin-bottom: var(--space-24);
}

.card-grid-3 {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
  gap: var(--space-24);
  margin-bottom: var(--space-24);
}

/* Status Cards Enhancement */
.status-card {
  display: flex;
  flex-direction: column;
  height: 100%;
  min-height: 140px;
}

.status-card .card-icon {
  font-size: 2rem;
  margin-bottom: var(--space-12);
}

.status-card .status-value {
  font-family: 'Syne', sans-serif;
  font-size: 1.5rem;
  font-weight: 700;
  color: var(--text-primary);
  margin: var(--space-8) 0;
}

.status-card .status-value.score {
  color: var(--accent);
}

.progress-bar {
  width: 100%;
  height: 6px;
  background: var(--bg-subtle);
  border-radius: 3px;
  overflow: hidden;
  margin-top: var(--space-8);
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--accent), var(--accent-hover));
  border-radius: 3px;
  transition: width 600ms ease;
}

/* Enhanced Activity Feed */
.activity-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-12);
}

.activity-item {
  display: flex;
  align-items: flex-start;
  gap: var(--space-12);
  padding: var(--space-12);
  border-radius: 6px;
  background: var(--bg-subtle);
  transition: background 200ms ease;
}

.activity-item:hover {
  background: var(--bg-elevated);
}

.activity-time {
  font-size: 0.8rem;
  color: var(--text-muted);
  font-family: 'JetBrains Mono', monospace;
  min-width: 80px;
}

.activity-icon {
  font-size: 1.1rem;
  min-width: 24px;
}

.activity-detail {
  flex: 1;
  font-size: 0.9rem;
  color: var(--text-secondary);
}

/* Responsive Design - Mobile First Approach */
@media (max-width: 1024px) {
  .sidebar {
    width: 240px;
  }
  
  main.with-sidebar {
    margin-left: 240px;
  }
  
  .card-grid {
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
  }
  
  .card-grid-3 {
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  }
}

@media (max-width: 768px) {
  .menu-toggle {
    display: flex;
  }
  
  .sidebar {
    transform: translateX(-100%);
    width: 280px;
    box-shadow: 2px 0 20px rgba(0, 0, 0, 0.3);
  }
  
  .sidebar.active {
    transform: translateX(0);
  }
  
  .sidebar-overlay.active {
    display: block;
    opacity: 1;
  }
  
  main.with-sidebar {
    margin-left: 0;
  }
  
  main {
    padding: var(--space-16);
  }
  
  .page-header {
    flex-direction: column;
    gap: var(--space-16);
    margin-top: var(--space-16);
  }
  
  .card-grid,
  .card-grid-3 {
    grid-template-columns: 1fr;
    gap: var(--space-16);
  }
  
  .notification-dropdown {
    width: calc(100vw - var(--space-32));
    right: var(--space-16);
    max-width: 360px;
  }
  
  .notification-bell {
    top: var(--space-16);
    right: var(--space-16);
  }
}

@media (max-width: 480px) {
  .sidebar {
    width: 100vw;
    border-right: none;
  }
  
  main {
    padding: var(--space-12);
  }
  
  .page-header h1 {
    font-size: 1.5rem;
  }
  
  .card {
    padding: var(--space-16);
  }
  
  .btn-primary,
  .btn-secondary {
    padding: var(--space-12) var(--space-16);
    font-size: 0.85rem;
  }
}